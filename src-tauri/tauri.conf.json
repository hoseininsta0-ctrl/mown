{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mown",
  "version": "1.0.0",
  "identifier": "com.mrmeshky.mown",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm prepare:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Mown",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "hardenedRuntime": true
    },
    "windows": {
      "nsis": {
      }
    },
    "linux": {}
  }
}
